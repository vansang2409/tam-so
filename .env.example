# Supabase Auth (public client config)
# Copy file nay thanh .env.local, dien gia tri tu Supabase Dashboard.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Legacy projects can use anon key instead:
# VITE_SUPABASE_ANON_KEY=eyJ...

# Optional: comma-separated emails allowed to open /admin from the client UI.
# Supabase still needs supabase/schema.sql admin policies for full profile management.
# VITE_ADMIN_EMAILS=admin@example.com,owner@example.com
